{
  "name": "openclaw-desktop",
  "version": "1.0.0",
  "description": "OpenClaw 中文版桌面客户端",
  "author": "josephxie1",
  "main": "main.js",
  "scripts": {
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.openclaw.desktop",
    "productName": "OpenClaw",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "gateway",
        "to": "gateway",
        "filter": [
          "**/*",
          "!.git",
          "!src/**"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "dmg": {
      "artifactName": "OpenClaw-${version}-standalone-${arch}.${ext}"
    }
  }
}
